# Normalizza i fine-riga: nel repo sempre LF, evita diff fantasma CRLF/LF
* text=auto eol=lf

# File di testo espliciti
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# File binari: nessuna conversione
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.icns  binary
*.woff  binary
*.woff2 binary
